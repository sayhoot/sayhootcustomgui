--// Main Loop
RunService.RenderStepped:Connect(function()
    -- MouseLock (with anti-antilock bypass)
    if Config.MouseLockEnabled and target and target.Parent then
        -- Calculate real velocity from position delta (bypasses Velocity property spoofing)
        local currentPos = target.Position
        local now = tick()
        if lastTargetPos and lastTargetTime then
            local dt = now - lastTargetTime
            if dt > 0 then
                local rawVel = (currentPos - lastTargetPos) / dt
                -- Clamp to reasonable human speed to reject any residual spikes
                if rawVel.Magnitude > VEL_CLAMP then
                    rawVel = rawVel.Unit * VEL_CLAMP
                end
                -- Smooth the velocity gently to reduce jitter (0.2 = less reactive than before)
                calculatedVelocity = calculatedVelocity:Lerp(rawVel, 0.2)
            end
        end
        lastTargetPos = currentPos
        lastTargetTime = now
        local targetPos = currentPos + (calculatedVelocity * Config.Prediction)
        local camRight = CurrentCamera.CFrame.RightVector
        -- Smoothed lateral lead: lerp separately at 0.1 so direction changes ease in gradually
        local velRight = calculatedVelocity:Dot(camRight)
        smoothedLateral = smoothedLateral + (velRight - smoothedLateral) * 0.1
        local dynamicLeftOffset = Config.LeftOffset + (smoothedLateral * Config.DynamicLead)
        local offsetVec = (camRight * dynamicLeftOffset) + Vector3.new(0, Config.UpOffset, 0)
        local finalPos = targetPos + offsetVec
        local finalScreenPos, onScreen = CurrentCamera:WorldToViewportPoint(finalPos)
        if onScreen then
            local mousePos = UserInputService:GetMouseLocation()
            -- Jump suppression: freeze vertical aim while target is airborne
            local targetHum = target.Parent and target.Parent:FindFirstChildOfClass("Humanoid")
            local isAirborne = targetHum and targetHum.FloorMaterial == Enum.Material.Air
            local effectiveY
            if isAirborne and lastGroundedScreenY then
                effectiveY = lastGroundedScreenY  -- hold Y at last grounded position
            else
                lastGroundedScreenY = finalScreenPos.Y
                effectiveY = finalScreenPos.Y
            end
            local deltaX = finalScreenPos.X - mousePos.X
            local deltaY = effectiveY - mousePos.Y
            -- Ease-in on toggle: ramp from 15% to 100% of configured smoothness over 0.5s
            local effectiveSmoothness = Config.Smoothness
            if lockActivatedAt then
                local elapsed = tick() - lockActivatedAt
                if elapsed < EASE_IN_DURATION then
                    local t = elapsed / EASE_IN_DURATION
                    effectiveSmoothness = Config.Smoothness * (0.15 + 0.85 * t)
                else
                    lockActivatedAt = nil
                end
            end
            local moveX = deltaX * effectiveSmoothness
            local moveY = deltaY * effectiveSmoothness
            if math.abs(moveX) > 0.01 or math.abs(moveY) > 0.01 then
                pcall(function()
                    -- Add subtle random noise to mimic human hand imprecision
                    local nx = (math.random() - 0.5) * 2 * Config.HumanNoise
                    local ny = (math.random() - 0.5) * 2 * Config.HumanNoise
                    mousemoverel(moveX + nx, moveY + ny)
                end)
            end
        end
    else
        -- Reset velocity tracking when not locked
        lastTargetPos = nil
        lastTargetTime = nil
        calculatedVelocity = Vector3.new(0, 0, 0)
        smoothedLateral = 0
        lastGroundedScreenY = nil
        lockActivatedAt = nil
    end
    -- HipHeight
    if Config.HipHeightEnabled and LocalPlayer.Character then
        local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then
            if not originalHipHeight then
                originalHipHeight = hum.HipHeight
            end
            hum.HipHeight = Config.HipHeightValue
        end
    end
end)
